{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/after-file-edit.sh",
        "timeout": 60
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/post-write-quality.sh",
        "matcher": "Write",
        "timeout": 90
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop-quality-gate.sh",
        "timeout": 300
      }
    ]
  }
}
